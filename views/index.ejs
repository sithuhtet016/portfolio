<section
  id="contact"
  class="mt-md-0 px-24px md:-top-10 position-relative top-63px px-24px"
>
  <h2
    class="font-rubik text-40px leading-52px text-center fw-bold pt-70px md:pt-0"
  >
    GET IN TOUCH
  </h2>
  <form
    action="https://formspree.io/f/xoqopwjy"
    method="post"
    class="max-w-362px max-w-md-fit mx-auto bg-color3 ring-6px rounded-8px mt-48px md:mt-14 px-24px"
  >
    <div class="d-md-flex align-items-md-baseline g-md-24px">
      <div>
        <label class="d-block pt-24px font-rubik text-18px fw-medium" for="name"
          >Your Name</label
        >
        <input
          id="name"
          name="name"
          required
          class="w-100 md:w-334px mt-12px border-0 ring-4px py-8px px-12px rounded-4px focus-ring-4px font-poppins text-16px"
          type="text"
          placeholder="John"
        />
      </div>
      <div>
        <label
          class="d-block pt-24px font-rubik text-18px fw-medium"
          for="email"
          >Your Email</label
        >
        <input
          id="email"
          name="email"
          required
          class="w-100 md:w-334px mt-12px border-0 ring-4px py-8px px-12px rounded-4px focus-ring-4px font-poppins text-16px"
          type="email"
          placeholder="john@gmail.com"
        />
      </div>
    </div>
    <label class="d-block pt-24px font-rubik text-18px fw-medium" for="textbox"
      >Your Message</label
    >
    <textarea
      id="textbox"
      name="message"
      required
      class="w-100 mt-12px border-0 ring-4px py-8px px-12px rounded-4px focus-ring-4px font-poppins text-16px md:h-56"
      name=""
      cols="30"
      rows="5"
      placeholder="Write your message here..."
    ></textarea>
    <div>
      <button
        type="submit"
        class="font-rubik text-17px leading-24px fw-medium px-24px py-8px border-0 ring-4px ring-orange bg-color5 rounded-4px hover-bg-color1 hover-ring-4px my-24px w-100"
      >
        Send Message
      </button>
    </div>
  </form>
</section>
